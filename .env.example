# Maps JavaScript API key (Google Cloud Console: APIs & Services → Credentials)
# Enable these APIs for full 3D functionality:
#   - Maps JavaScript API (required)
#   - Geocoding API (address search)
#   - Map Tiles API (photorealistic 3D buildings where available)
GOOGLE_MAPS_API_KEY=your_browser_key_here

# Optional: cloud-based map style ID from Google Cloud Console
# GOOGLE_MAP_ID=your_map_id_here

# Server configuration
PORT=3000
